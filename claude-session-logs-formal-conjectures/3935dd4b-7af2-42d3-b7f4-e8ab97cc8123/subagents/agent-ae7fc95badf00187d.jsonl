n space is two-dimensional. -/\n    40→instance fact_finrank_euclideanSpace_fin_two : Fact (Module.finrank ℝ ℝ² = 2) :=\n    41→  ⟨finrank_euclideanSpace_fin⟩\n    42→\n    43→open scoped EuclideanGeometry\n    44→\n    45→open scoped Real\n    46→\n    47→namespace EuclideanGeometry\n    48→\n    49→variable {V P : Type*} {n : ℕ}\n    50→\n    51→variable [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P] [NormedAddTorsor V P]\n    52→\n    53→variable [Module.Oriented ℝ V (Fin 2)] [Fact (Module.finrank ℝ V = 2)] {p : Fin n → P}\n    54→\n    55→/-- We say a subset `A` of points in the plane is non-trilinear\n    56→if it contains no three points that lie on the same line. -/\n    57→def NonTrilinear (A : Set P) : Prop :=\n    58→  A.Triplewise (fun x y z ↦ ¬ Collinear ℝ {x, y, z})\n    59→\n    60→/-- `ConvexIndep S` means that `S` consists of extremal points of its convex hull,\n    61→i.e., the point set encloses a convex shape.\n    62→Also known as a \"convex-independent set\". -/\n    63→def ConvexIndep (S : Set ℝ²) : Prop :=\n    64→  ∀ a ∈ S, a ∉ convexHull ℝ (S \\ {a})\n    65→\n    66→/-- The set `P` contains a convex `n`-gon.\n    67→See also `IsConvexPolygon`. -/\n    68→def HasConvexNGon (n : ℕ) (P : Set ℝ²) : Prop :=\n    69→  ∃ S : Finset ℝ², S.card = n ∧ ↑S ⊆ P ∧ ConvexIndep S\n    70→\n    71→/-- The statement that a sequence of points form a counter-clockwise convex polygon. -/\n    72→def IsCcwConvexPolygon (p : Fin n → P) : Prop :=\n    73→  ∀ ⦃i j k⦄, i < j → j < k → (∡ (p i) (p j) (p k)).sign = 1\n    74→\n    75→theorem IsCcwConvexPolygon.sign_oangle (hp : IsCcwConvexPolygon p) {i j k : Fin n}\n    76→  (hij : i < j) (hjk : j < k) : (∡ (p i) (p j) (p k)).sign = 1 := hp hij hjk\n    77→\n    78→set_option linter.docPrime false in\n    79→theorem IsCcwConvexPolygon.sign_oangle' (hp : IsCcwConvexPolygon p) {i j k : Fin n}\n    80→    (hij : i < j) (hjk : j < k) : (∡ (p j) (p k) (p i)).sign = 1 := by\n    81→  rw [EuclideanGeometry.oangle_rotate_sign]\n    82→  exact hp hij hjk\n    83→\n    84→set_option linter.docPrime false in\n    85→theorem IsCcwConvexPolygon.sign_oangle'' (hp : IsCcwConvexPolygon p) {i j k : Fin n}\n    86→    (hij : i < j) (hjk : j < k) : (∡ (p k) (p i) (p j)).sign = 1 := by\n    87→  rw [← EuclideanGeometry.oangle_rotate_sign]\n    88→  exact hp hij hjk\n    89→\n    90→theorem IsCcwConvexPolygon.sign_oangle_finRotate (hp : IsCcwConvexPolygon p)\n    91→    (hn : 3 ≤ n) (i : Fin n) :\n    92→    (∡ (p i) (p <| finRotate _ i) (p <| finRotate _ (finRotate _ i))).sign = 1 := by\n    93→  obtain ⟨n, rfl⟩ := le_iff_exists_add'.mp hn\n    94→  by_cases hi : i = Fin.last (n + 2)\n    95→  · rw [hi, finRotate_last, finRotate_apply_zero]\n    96→    exact hp.sign_oangle'' Fin.zero_lt_one Fin.one_lt_last\n    97→  by_cases hi' : finRotate _ i = Fin.last (n + 2)\n    98→  · rw [hi', finRotate_last]\n    99→    refine hp.sign_oangle' ?_ ((Fin.le_last _).lt_of_ne hi)\n   100→    rw [Fin.pos_iff_ne_zero]\n   101→    rintro rfl\n   102→    rw [finRotate_apply_zero] at hi'\n   103→    exact Fin.one_lt_last.ne hi'\n   104→  apply hp.sign_oangle <;> apply lt_finRotate_of_ne_last <;> assumption\n   105→\n   106→@[simp] theorem isCcwConvexPolygon_zero (p : Fin 0 → P) : IsCcwConvexPolygon p := finZeroElim\n   107→\n   108→@[simp] theorem isCcwConvexPolygon_one (p : Fin 1 → P) : IsCcwConvexPolygon p := by intro; omega\n   109→\n   110→@[simp] theorem isCcwConvexPolygon_two (p : Fin 2 → P) : IsCcwConvexPolygon p := by intro; omega\n   111→\n   112→set_option linter.docPrime false in\n   113→theorem isCcwConvexPolygon_four' {p : Fin 4 → P} :\n   114→    IsCcwConvexPolygon p ↔ (∡ (p 0) (p 1) (p 2)).sign = 1 ∧ (∡ (p 1) (p 2) (p 3)).sign = 1 ∧\n   115→    (∡ (p 2) (p 3) (p 0)).sign = 1 ∧ (∡ (p 3) (p 0) (p 1)).sign = 1 := by\n   116→  refine ⟨fun h ↦ ?_, fun ⟨h1, h2, h3, h4⟩ ↦ ?_⟩\n   117→  · obtain ⟨h01, h12, h23⟩ : (0 : Fin 4) < 1 ∧ (1 : Fin 4) < 2 ∧ (2 : Fin 4) < 3 := by simp\n   118→    · repeat' constructor\n   119→      · exact h.sign_oangle h01 h12\n   120→      · exact h.sign_oangle h12 h23\n   121→      · exact h.sign_oangle' (h01.trans h12) h23\n   122→      · exact h.sign_oangle'' h01 (h12.trans h23)\n   123→  · intro i j k hij hjk\n   124→    fin_cases i <;> fin_cases j <;> fin_cases k <;> simp at hij hjk\n   125→    · exact h1\n   126→    · rw [EuclideanGeometry.oangle_rotate_sign]\n   127→      exact h4\n   128→    · rw [← EuclideanGeometry.oangle_rotate_sign]\n   129→      exact h3\n   130→    · exact h2\n   131→\n   132→@[simp]\n   133→theorem isCcwConvexPolygon_four (A B C D : P) :\n   134→    IsCcwConvexPolygon ![A, B, C, D] ↔\n   135→      (∡ A B C).sign = 1 ∧ (∡ B C D).sign = 1 ∧ (∡ C D A).sign = 1 ∧ (∡ D A B).sign = 1 :=\n   136→  isCcwConvexPolygon_four'\n   137→\n   138→/-- The statement that a sequence of points form a convex polygon. -/\n   139→def IsConvexPolygon {n : ℕ} (p : Fin n → P) : Prop :=\n   140→  IsCcwConvexPolygon p ∨ IsCcwConvexPolygon fun i => p (-i)\n   141→\n   142→/-- Three affine independent points always form a convex polygon. -/\n   143→theorem isConvexPolygon_three_of_affineIndependent {A B C : P}\n   144→    (hABC : AffineIndependent ℝ ![A, B, C]) : IsConvexPolygon ![A, B, C] := by\n   145→  rw [← oangle_ne_zero_and_ne_pi_iff_affineIndependent, ← Real.Angle.sign_ne_zero_iff] at hABC\n   146→  cases hsABC : (∡ A B C).sign\n   147→  · exact (hABC hsABC).elim\n   148→  · right\n   149→    intro i j k hij hjk\n   150→    fin_cases i <;> fin_cases j <;> fin_cases k <;> simp at hij hjk\n   151→    rw [EuclideanGeometry.oangle_rev, Real.Angle.sign_neg, neg_eq_iff_eq_neg]\n   152→    exact (oangle_rotate_sign A B C).trans hsABC\n   153→  · left\n   154→    intro i j k hij hjk\n   155→    fin_cases i <;> fin_cases j <;> fin_cases k <;> simp at hij hjk\n   156→    exact hsABC\n   157→\n   158→theorem isConvexPolygon_three_iff_affineIndependent {A B C : P} :\n   159→    IsConvexPolygon ![A, B, C] ↔ AffineIndependent ℝ ![A, B, C] := by\n   160→  refine ⟨fun h => ?_, isConvexPolygon_three_of_affineIndependent⟩\n   161→  rw [← oangle_ne_zero_and_ne_pi_iff_affineIndependent, ← Real.Angle.sign_ne_zero_iff]\n   162→  let p := ![A, B, C]\n   163→  change IsConvexPolygon p at h\n   164→  change Real.Angle.sign (∡ (p 0) (p 1) (p 2)) ≠ 0\n   165→  cases h with\n   166→  | inl h =>\n   167→    rw [h.sign_oangle (by simp) (by simp)]\n   168→    rintro ⟨⟩\n   169→  | inr h =>\n   170→    suffices Real.Angle.sign (∡ (p 0) (p 2) (p 1)) = 1 by rw [← oangle_swap₂₃_sign, this]; rintro ⟨⟩\n   171→    exact h.sign_oangle (i := 0) (j := 1) (k := 2) (by simp) (by simp)\n   172→\n   173→theorem isConvexPolygon_triangle (t : Affine.Triangle ℝ P) : IsConvexPolygon t.points := by\n   174→  have : t.points = ![t.points 0, t.points 1, t.points 2] := by ext i; fin_cases i <;> rfl\n   175→  rw [this, isConvexPolygon_three_iff_affineIndependent, ← this]\n   176→  exact t.independent\n   177→\n   178→noncomputable def triangle_area (a b c : P) : ℝ :=\n   179→  positiveOrientation.areaForm (a -ᵥ c) (b -ᵥ c) / 2\n   180→\n   181→lemma triangle_area_eq_det (a b c : ℝ²) :\n   182→    triangle_area a b c =\n   183→    Matrix.det !![a 0, b 0, c 0;\n   184→                  a 1, b 1, c 1;\n   185→                  1,   1,   1] / 2 := by\n   186→  rw [triangle_area, Orientation.areaForm_to_volumeForm,\n   187→    positiveOrientation.volumeForm_robust (EuclideanSpace.basisFun (Fin 2) ℝ) rfl, Module.Basis.det_apply]\n   188→  suffices (a 0 - c 0) * (b 1 - c 1) - (b 0 - c 0) * (a 1 - c 1) =\n   189→      a 0 * b 1 - a 0 * c 1 - b 0 * a 1 + b 0 * c 1 + c 0 * a 1 - c 0 * b 1 by\n   190→    simp [Matrix.det_fin_two, Matrix.det_fin_three, Module.Basis.toMatrix, this]\n   191→  ring\n   192→\n   193→/--\n   194→Given a finite set of points in the plane, we define the number of distinct distances between pairs\n   195→of points.\n   196→-/\n   197→noncomputable def distinctDistances (points : Finset ℝ²) : ℕ :=\n   198→  (points.offDiag.image fun (pair : ℝ² × ℝ²) => dist pair.1 pair.2).card\n   199→\n   200→\n   201→/-- Given a finite set of points in the, we define the number of distinct distances between\n   202→a given point and all other points -/\n   203→noncomputable def distinctDistancesFrom (points : Finset ℝ²) (pt : ℝ²) : ℕ :=\n   204→  (points.image fun x => dist x pt).card\n   205→\n   206→end EuclideanGeometry\n   207→\n   208→\n   209→def IsIsosceles {α : Type*} [Dist α] (p q r : α) : Prop :=\n   210→  dist p q = dist q r ∨ dist q r = dist r p ∨ dist r p = dist p q\n   211→\n   212→nonrec def Set.IsIsosceles {α : Type} [Dist α] (A : Set α) :=\n   213→  Nonempty A ∧ A.Triplewise (IsIsosceles · · ·)\n   214→"}]},"uuid":"634c586c-f5bb-452b-810a-4bf29ab2b3cd","timestamp":"2026-03-15T01:39:53.097Z","sourceToolAssistantUUID":"8498f133-ad4c-47dc-bf65-856999c75a7a","userType":"external","cwd":"/home/ryan/formal-conjectures","sessionId":"3935dd4b-7af2-42d3-b7f4-e8ab97cc8123","version":"2.1.74","gitBranch":"erdos-all","slug":"reactive-zooming-church"}
